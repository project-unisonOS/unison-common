{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.unisonos.org/governed-context.v2.schema.json",
  "title": "Unison governed context contracts",
  "type": "object",
  "oneOf": [
    {"$ref": "#/$defs/relationship"},
    {"$ref": "#/$defs/contextSpace"},
    {"$ref": "#/$defs/membership"},
    {"$ref": "#/$defs/memoryRecord"},
    {"$ref": "#/$defs/goal"},
    {"$ref": "#/$defs/commitment"},
    {"$ref": "#/$defs/personalCharter"}
  ],
  "$defs": {
    "identifier": {"type": "string", "minLength": 1},
    "contextSpace": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "space_id", "kind", "owner_person_id", "name", "purpose", "key_handle", "key_version"],
      "properties": {
        "version": {"const": "2.0"},
        "space_id": {"$ref": "#/$defs/identifier"},
        "kind": {"enum": ["private", "shared", "system", "ephemeral"]},
        "owner_person_id": {"$ref": "#/$defs/identifier"},
        "assistant_instance_id": {"type": ["string", "null"]},
        "name": {"$ref": "#/$defs/identifier"},
        "purpose": {"$ref": "#/$defs/identifier"},
        "key_handle": {"$ref": "#/$defs/identifier"},
        "key_version": {"type": "integer", "minimum": 1},
        "created_at": {"type": "string", "format": "date-time"},
        "deleted_at": {"type": ["string", "null"], "format": "date-time"}
      }
    },
    "membership": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "membership_id", "space_id", "person_id", "role"],
      "properties": {
        "version": {"const": "2.0"},
        "membership_id": {"$ref": "#/$defs/identifier"},
        "space_id": {"$ref": "#/$defs/identifier"},
        "person_id": {"$ref": "#/$defs/identifier"},
        "role": {"enum": ["owner", "editor", "viewer"]},
        "invited_by": {"type": ["string", "null"]},
        "created_at": {"type": "string", "format": "date-time"},
        "removed_at": {"type": ["string", "null"], "format": "date-time"}
      }
    },
    "relationship": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "relationship_id", "owner_person_id", "subject_id", "label", "provenance", "confidence"],
      "properties": {
        "version": {"const": "2.0"},
        "relationship_id": {"$ref": "#/$defs/identifier"},
        "owner_person_id": {"$ref": "#/$defs/identifier"},
        "subject_id": {"$ref": "#/$defs/identifier"},
        "label": {"$ref": "#/$defs/identifier"},
        "context_tags": {"type": "array", "items": {"type": "string"}},
        "provenance": {"$ref": "#/$defs/identifier"},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "created_at": {"type": "string", "format": "date-time"},
        "deleted_at": {"type": ["string", "null"], "format": "date-time"}
      }
    },
    "governance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sensitivity", "purposes", "audiences", "allow_inference", "allow_action", "allow_disclosure", "allow_backup", "allow_sync"],
      "properties": {
        "sensitivity": {"type": "string"},
        "purposes": {"type": "array", "items": {"type": "string"}},
        "audiences": {"type": "array", "items": {"type": "string"}},
        "allow_inference": {"type": "boolean"},
        "allow_action": {"type": "boolean"},
        "allow_disclosure": {"type": "boolean"},
        "allow_backup": {"type": "boolean"},
        "allow_sync": {"type": "boolean"},
        "retention_until": {"type": ["string", "null"], "format": "date-time"}
      }
    },
    "memoryRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "record_id", "owner_person_id", "space_id", "kind", "content", "provenance", "governance", "confidence", "revision", "deletion_state"],
      "properties": {
        "version": {"const": "2.0"},
        "record_id": {"$ref": "#/$defs/identifier"},
        "owner_person_id": {"$ref": "#/$defs/identifier"},
        "space_id": {"$ref": "#/$defs/identifier"},
        "kind": {"enum": ["asserted_fact", "imported_data", "inferred_hypothesis", "user_correction", "summary", "derived_index", "calendar_event", "grocery_item"]},
        "content": {"type": "object"},
        "provenance": {"$ref": "#/$defs/identifier"},
        "source_record_id": {"type": ["string", "null"]},
        "relationship_ids": {"type": "array", "items": {"type": "string"}},
        "governance": {"$ref": "#/$defs/governance"},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "revision": {"type": "integer", "minimum": 1},
        "deletion_state": {"enum": ["active", "deleted", "expired"]},
        "created_at": {"type": "string", "format": "date-time"},
        "updated_at": {"type": "string", "format": "date-time"}
      }
    },
    "goal": {
      "type": "object",
      "required": ["version", "goal_id", "person_id", "space_id", "title", "origin", "revision"],
      "properties": {
        "version": {"const": "2.0"}, "goal_id": {"$ref": "#/$defs/identifier"},
        "person_id": {"$ref": "#/$defs/identifier"}, "space_id": {"$ref": "#/$defs/identifier"},
        "title": {"$ref": "#/$defs/identifier"}, "origin": {"$ref": "#/$defs/identifier"},
        "status": {"type": "string"}, "revision": {"type": "integer", "minimum": 1}
      }
    },
    "commitment": {
      "type": "object",
      "required": ["version", "commitment_id", "person_id", "space_id", "title", "origin", "state", "revision"],
      "properties": {
        "version": {"const": "2.0"}, "commitment_id": {"$ref": "#/$defs/identifier"},
        "person_id": {"$ref": "#/$defs/identifier"}, "space_id": {"$ref": "#/$defs/identifier"},
        "title": {"$ref": "#/$defs/identifier"}, "origin": {"$ref": "#/$defs/identifier"},
        "state": {"enum": ["open", "completed", "cancelled"]},
        "due_at": {"type": ["string", "null"], "format": "date-time"},
        "revision": {"type": "integer", "minimum": 1}
      }
    },
    "personalCharter": {
      "type": "object",
      "required": ["version", "charter_id", "person_id", "principles", "prohibited_objectives", "origin", "revision"],
      "properties": {
        "version": {"const": "2.0"}, "charter_id": {"$ref": "#/$defs/identifier"},
        "person_id": {"$ref": "#/$defs/identifier"},
        "principles": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "prohibited_objectives": {"type": "array", "items": {"type": "string"}},
        "origin": {"$ref": "#/$defs/identifier"}, "revision": {"type": "integer", "minimum": 1}
      }
    }
  }
}
