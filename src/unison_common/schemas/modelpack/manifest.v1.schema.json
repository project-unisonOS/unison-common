{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://unisonos.ai/schemas/modelpack/manifest.v1.schema.json",
  "title": "ModelPackManifestV1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "pack", "models", "files"],
  "properties": {
    "schema_version": { "type": "string", "const": "unison.modelpack.manifest.v1" },
    "pack": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version"],
      "properties": {
        "id": { "type": "string", "minLength": 3 },
        "version": { "type": "string", "minLength": 1 },
        "created_at": { "type": "string" },
        "description": { "type": "string" }
      }
    },
    "compat": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "os": { "type": "array", "items": { "type": "string" } },
        "arch": { "type": "array", "items": { "type": "string" } },
        "gpu": { "type": "string", "enum": ["none", "optional", "required"] }
      }
    },
    "models": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["model_id", "engine", "install_relpath", "required"],
        "properties": {
          "model_id": { "type": "string", "minLength": 3 },
          "engine": { "type": "string", "minLength": 2 },
          "role": { "type": "string" },
          "install_relpath": { "type": "string", "minLength": 1 },
          "required": { "type": "boolean" },
          "notes": { "type": "string" }
        }
      }
    },
    "files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "sha256", "size_bytes"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
          "size_bytes": { "type": "integer", "minimum": 0 },
          "model_ids": { "type": "array", "items": { "type": "string" }, "default": [] }
        }
      }
    }
  }
}

