{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.unisonos.org/principal-context.v1.schema.json",
  "title": "PrincipalContext v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "principal_id", "principal_kind", "auth_method", "assurance", "token_id", "issued_at", "expires_at"],
  "properties": {
    "version": {"const": "1.0"},
    "principal_id": {"type": "string", "minLength": 1},
    "principal_kind": {"enum": ["person", "workload", "device", "channel"]},
    "person_id": {"type": ["string", "null"]},
    "assistant_instance_id": {"type": ["string", "null"]},
    "household_id": {"type": ["string", "null"]},
    "membership_id": {"type": ["string", "null"]},
    "device_principal_id": {"type": ["string", "null"]},
    "channel_identity_id": {"type": ["string", "null"]},
    "login_handle": {"type": ["string", "null"]},
    "display_name": {"type": ["string", "null"]},
    "roles": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "scopes": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "audience": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "auth_method": {"type": "string", "minLength": 1},
    "assurance": {"enum": ["low", "medium", "high", "hardware"]},
    "session_id": {"type": ["string", "null"]},
    "delegation_id": {"type": ["string", "null"]},
    "delegated_by": {"type": ["string", "null"]},
    "key_handle": {"type": ["string", "null"]},
    "credential_namespace": {"type": ["string", "null"]},
    "data_namespace": {"type": ["string", "null"]},
    "cache_namespace": {"type": ["string", "null"]},
    "index_namespace": {"type": ["string", "null"]},
    "token_id": {"type": "string", "minLength": 1},
    "issued_at": {"type": "integer", "minimum": 1},
    "expires_at": {"type": "integer", "minimum": 1},
    "trace_id": {"type": ["string", "null"]}
  }
}
